# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space

max_line_length = 100
insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
tab_width = 2
indent_size = 2

[*.{yml,yaml}]
tab_width = 2
indent_size = 2

[*.xml]
ij_xml_attribute_wrap = off
ij_xml_text_wrap = off
ij_xml_keep_blank_lines = 1

[pom.xml]
indent_size = 2

[*.java]
indent_size = 4
tab_width = 4

[*.md]
trim_trailing_whitespace = false

[*.properties]
indent_size = 4

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab
